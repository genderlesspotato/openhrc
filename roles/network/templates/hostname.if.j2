# {{ ansible_managed }}

{% if item.value.ip4 == 'dhcp' %}
dhcp
{% else %}
{% set ip = item.value.ip4 | ansible.utils.ipv4('host/prefix') %}
inet {{ ip | ansible.utils.ipaddr('address') }} {{ ip | ansible.utils.ipaddr('netmask') }} NONE
{% endif %}
{% if item.value.description %}
description "{{ item.value.description }}"
{% endif %}
up
